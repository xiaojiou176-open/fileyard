# =========================
# Fileman environment template
# SSOT facts: contracts/runtime/env_contract_registry.yaml
# Policy / explain: docs/env_contract.md
# For a durable runtime file, copy the keys you need into <workspace-root>/.fileman/env/runtime.env.
# The repository root .env file is local-only convenience and is not a supported runtime source.
# Sensitive values policy: only set via <workspace-root>/.fileman/env/runtime.env or shell environment variables.
# =========================

# [Minimal template - required]
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
# The remaining variables stay as commented placeholders.
# Enable them only when needed; they are not part of the minimum local setup.

# [runtime-optional - live integration]
# FILEMAN_RUN_LIVE_TESTS=0
# FILEMAN_LIVE_TEST_URL=
# FILEMAN_LIVE_COVERAGE_FILE=
# LIVE_COVERAGE_FILE=
# LIVE_HEARTBEAT_INTERVAL_SECONDS=20
# LIVE_MAX_DURATION_SECONDS=600
# LIVE_MAX_RETRIES=2

# [runtime-optional - rollback strict integrity]
# This key is required when `strict_integrity=true` (the default for CLI/Web rollback).
# Disabling strict integrity weakens rollback verification guarantees and should only
# be used in tightly controlled debugging scenarios.
# FILEMAN_ROLLBACK_HMAC_KEY=

# [runtime-optional - container execution]
# FILEMAN_ALLOW_HOST_EXECUTION=0
# FILEMAN_ALLOW_EXTERNAL=0
# FILEMAN_COMPOSE_FILE=docker-compose.yml
# FILEMAN_COMPOSE_SERVICE=fileman-ci
# FILEMAN_CI_IMAGE=ghcr.io/<owner>/fileman-ci@sha256:<digest>
# FILEMAN_PREBUILT_VENV_DIR=/opt/fileman-ci-venv
# FILEMAN_WORKSPACE_ROOT=<workspace-root>
# FILEMAN_INPUT_ROOT=<workspace-root>/data/raw
# FILEMAN_OUTPUT_ROOT=<workspace-root>/data/organized
# FILEMAN_MANIFEST_ROOT=<workspace-root>/.fileman/manifests
# FILEMAN_ARTIFACT_ROOT=<workspace-root>/.fileman/artifacts
# FILEMAN_EVIDENCE_BUNDLE_PATH=<workspace-root>/.fileman/artifacts/evidence-bundle.json
# FILEMAN_RUN_BUNDLE_ROOT=<workspace-root>/.fileman/runs
# FILEMAN_RUN_DIR=
# FILEMAN_RUN_EVENTS_PATH=
# FILEMAN_RUN_STDERR_PATH=
# FILEMAN_RUN_SUMMARY_PATH=
# FILEMAN_RUN_EVIDENCE_INDEX_PATH=
# FILEMAN_WEB_API_HOST=127.0.0.1
# FILEMAN_WEB_API_PORT=18080
# FILEMAN_WEBUI_HOST=127.0.0.1
# FILEMAN_WEBUI_PORT=5173
# FILEMAN_VENV_DIR=~/.cache/fileman/venv/default
# FILEMAN_ATOMIC_ALLOWLIST=
# FILEMAN_ATOMIC_MAX_FILES=12
# FILEMAN_ATOMIC_MAX_LINES=400
# FILEMAN_CLI_REPORT_BUDGET_MS=1500
# FILEMAN_PRE_PUSH_MODE=standard
# FILEMAN_REQUIRE_NON_EMPTY_RANGE=0
# FILEMAN_ROLLBACK_RTO_BUDGET_MS=3000

# [runtime-optional - script safety overrides]
# CLEAN_CACHE_ROOT=
# HEARTBEAT_INTERVAL_SECONDS=30
# GEMINI_UI_AUDIT_MODEL=gemini-3-flash-preview
# GEMINI_UI_AUDIT_TIMEOUT_MS=90000
# QUALITY_GATE_MAX_STEP_SECONDS=0
# QUALITY_GATE_ALLOW_LIVE_NETWORK_TIMEOUT=1
# PYTEST_HEARTBEAT_NAME=pytest
# PYTEST_MAX_DURATION_SECONDS=0

# [runtime-optional - observability context]
# FILEMAN_TRACE_ID=
# FILEMAN_SESSION_ID=
# FILEMAN_REQUEST_ID=
# FILEMAN_USER_ID=cli_anonymous

# [ci-only / test-only placeholders, do not set manually]
# FILEMAN_IN_CONTAINER=1
# FILEMAN_ENABLE_TEST_HOOKS=0
# FILEMAN_APPLY_CRASH_AT=
# PYTEST_CURRENT_TEST=
# PRE_COMMIT_FROM_REF=
# PRE_COMMIT_TO_REF=
# LIVE_TEST_PID=
