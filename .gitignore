脚本/_test_e2e/

# Coverage临时文件 - 只保留主文件
coverage*.xml
!coverage.xml

# Research/chat transcript noise
docs/_archive/我和ChatGPT的完整对话.md

# 二进制构建产物
*.so
*.dylib
*.dll
*.pyd

# Codex / Kiro / Claude rollout JSONL — 这类文件会包含 token / secret，永远不能 commit
.archive/sessions/
.archive/**/sessions/
.archive/**/*.jsonl
.codex/sessions/
.kiro/sessions/
.claude/sessions/
**/rollout-*.jsonl
**/session-*.jsonl

# Common secret files (patch 2026-05-27)
*.key
*.pem
id_rsa
id_ed25519
*.p12
*.pfx


# .archive/ 全部 ignore（5/27 v3 加固）
.archive/
