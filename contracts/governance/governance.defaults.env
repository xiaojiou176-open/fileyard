GOVERNANCE_RUNTIME_LOG_DIR=.runtime-cache/logs
GOVERNANCE_RUNTIME_CI_DIR=.runtime-cache/ci
GOVERNANCE_RUNTIME_CI_CONTRACT_DIR=.runtime-cache/ci-contract
GOVERNANCE_RUNTIME_TEST_DIR=.runtime-cache/test
GOVERNANCE_RUNTIME_BUILD_DIR=.runtime-cache/build
GOVERNANCE_RUNTIME_CODEGEN_DIR=.runtime-cache/codegen
GOVERNANCE_RUNTIME_VENV_DIR=~/.cache/fileyard/venv/default
GOVERNANCE_RUNTIME_MUTMUT_CACHE_FILE=.runtime-cache/test/mutation/.mutmut-cache
GOVERNANCE_NPM_CACHE_DIR=~/.cache/fileyard/npm
GOVERNANCE_PIP_CACHE_DIR=~/.cache/fileyard/pip
GOVERNANCE_XDG_CACHE_DIR=~/.cache/fileyard/xdg
GOVERNANCE_PRE_COMMIT_CACHE_DIR=~/.cache/fileyard/pre-commit
GOVERNANCE_PLAYWRIGHT_CACHE_DIR=~/.cache/fileyard/playwright
GOVERNANCE_WORKSPACE_ROOT=~/.fileyard/workspaces/default
