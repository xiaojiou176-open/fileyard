GOVERNANCE_WORKSPACE_OUTPUT_DIR=~/.fileyard/workspaces/default/data/organized
GOVERNANCE_MANIFEST_ROOT=~/.fileyard/workspaces/default/.fileyard/manifests
GOVERNANCE_PERSISTENT_ARTIFACTS_DIR=~/.fileyard/workspaces/default/.fileyard/artifacts
