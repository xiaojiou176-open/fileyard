GOVERNANCE_PIP_CACHE_DIR=~/.cache/fileman/pip
GOVERNANCE_XDG_CACHE_DIR=~/.cache/fileman/xdg
GOVERNANCE_PRE_COMMIT_CACHE_DIR=~/.cache/fileman/pre-commit
