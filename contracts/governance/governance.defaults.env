GOVERNANCE_NODE_MAJOR=24
GOVERNANCE_WEBUI_INSTALL_MODE=lockfile-ci
GOVERNANCE_COMPOSE_PROJECT_NAME_DEFAULT=fileorganize-web-stack
GOVERNANCE_MACHINE_CACHE_ROOT=~/.cache/fileorganize
GOVERNANCE_RUNTIME_CACHE_ROOT=.runtime-cache
