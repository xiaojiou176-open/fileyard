GOVERNANCE_RUNTIME_TEST_DIR=.runtime-cache/test
GOVERNANCE_RUNTIME_BUILD_DIR=.runtime-cache/build
GOVERNANCE_RUNTIME_CODEGEN_DIR=.runtime-cache/codegen
GOVERNANCE_RUNTIME_VENV_DIR=~/.cache/fileorganize/venv/default
GOVERNANCE_RUNTIME_MUTMUT_CACHE_FILE=.runtime-cache/test/mutation/.mutmut-cache
GOVERNANCE_NPM_CACHE_DIR=~/.cache/fileorganize/npm
GOVERNANCE_PIP_CACHE_DIR=~/.cache/fileorganize/pip
GOVERNANCE_XDG_CACHE_DIR=~/.cache/fileorganize/xdg
GOVERNANCE_PRE_COMMIT_CACHE_DIR=~/.cache/fileorganize/pre-commit
GOVERNANCE_PLAYWRIGHT_CACHE_DIR=~/.cache/fileorganize/playwright
